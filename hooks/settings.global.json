{
  "_comment": "이 hooks 블록을 ~/.claude/settings.json의 hooks 키에 병합한다(파일 통째 교체 아님). 크로스플랫폼: 훅은 macOS/Linux에서 sh -c, Windows에서 Git Bash로 실행되며 'node'가 PATH에 있어야 한다. 배선법: hooks/README.md. 세션/메모리 지속은 훅이 아니라 Claude Code 네이티브 메모리를 쓴다.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [{ "type": "command", "command": "node ~/.claude/hooks/guard-bash.mjs" }]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [{ "type": "command", "command": "node ~/.claude/hooks/guard-files.mjs" }]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [{ "type": "command", "command": "node ~/.claude/hooks/post-format.mjs" }]
      }
    ]
  }
}
