{
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/pre-compact.sh",
            "timeout": 10,
            "statusMessage": "Saving handoff artifact..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact|startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/post-compact.sh",
            "statusMessage": "Restoring context..."
          }
        ]
      }
    ]
  }
}
